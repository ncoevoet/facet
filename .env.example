# Facet deployment knobs. Copy to `.env` and edit — docker compose reads it automatically.
# These are the only things most deployments need to change; the rest lives in the
# baked default scoring_config.json (mount your own to customize further).

# VRAM profile: auto | legacy | 8gb | 16gb | 24gb
#   auto  -> detects from the GPU (16 GB card => 16gb; no GPU => legacy)
#   Overrides models.vram_profile in the config (honored by config/scoring_config.py).
FACET_VRAM_PROFILE=auto

# Host directory of photos to analyze (bind-mounted read-write into the container —
# writable so sidecar/XMP export can write next to the originals).
PHOTOS_DIR=./photos

# Host port to expose the web viewer on (container always listens on 5000).
PORT=5000

# Database path inside the container (kept on the ./data bind mount).
DB_PATH=/app/data/photo_scores_pro.db
